<script>
    // Hàm thay đổi tỉ số
    function changeScore(id, value) {
        let scoreElement = document.getElementById(id);
        let currentScore = parseInt(scoreElement.innerText);
        let newScore = currentScore + value;
        if (newScore < 0) newScore = 0; // Không cho điểm âm
        scoreElement.innerText = newScore;
    }

    // Hàm xem trước ảnh khi upload
    function previewImage(event, previewId) {
        let reader = new FileReader();
        reader.onload = function(){
            let output = document.getElementById(previewId);
            output.src = reader.result;
            output.style.display = "block";
        };
        reader.readAsDataURL(event.target.files[0]);
    }
</script>

